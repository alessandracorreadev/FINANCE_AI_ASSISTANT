<%= form_with url: month_chat_messages_path(month), method: :post, id: "message-form", class: "d-flex", html: { autocomplete: "off" } do |f| %>
  <div class="input-group input-group-sm flex-grow-1">
    <%= text_field_tag "message[content]", nil, class: "form-control", placeholder: "Type your question...", required: true, autocomplete: "off" %>
    <button type="submit" class="btn btn-primary ms-2">Send</button>
  </div>
<% end %>
