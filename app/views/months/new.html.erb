<div class="container-fluid min-vh-100">
  <div class="row align-items-center">

    <!-- Coluna do texto -->
    <div class="col-12 col-lg-6 px-4 px-lg-5 mb-5 mb-lg-0">
      <p class="text-success text-uppercase small fw-semibold mb-4">Finance AI Assistant</p>

      <h1 class="display-5 display-lg-4 fw-bold mb-3">
        Add a new month <span class="text-success">and track your finances.</span>
      </h1>

      <p class="text-muted mb-4 mb-lg-5">
        Fill in the details for this month. Include your income, expenses, and any notes.
        Then chat with the AI assistant to get personalized financial advice.
      </p>

      <%= link_to "Back to months",
                  months_path,
                  class: "btn btn-outline-secondary btn-lg w-100 w-lg-auto" %>
    </div>

    <!-- Coluna do formulário -->
    <div class="col-12 col-lg-6 d-flex justify-content-center px-3 px-lg-0">
      <div class="card shadow-sm w-100" style="max-width: 500px;">
        <div class="card-body p-4">
          <h4 class="card-title mb-4">New Month</h4>

          <%= simple_form_for @month do |f| %>

            <%= f.input :year,
                        placeholder: "e.g. 2026",
                        input_html: { class: "form-control" } %>

            <%= f.input :month,
                        collection: [
                          ["January", "January"],
                          ["February", "February"],
                          ["March", "March"],
                          ["April", "April"],
                          ["May", "May"],
                          ["June", "June"],
                          ["July", "July"],
                          ["August", "August"],
                          ["September", "September"],
                          ["October", "October"],
                          ["November", "November"],
                          ["December", "December"]
                        ],
                        prompt: "Select a month",
                        input_html: { class: "form-select" } %>

            <%= f.input :overview,
                        as: :text,
                        placeholder: "Describe your income, expenses, goals for this month...",
                        input_html: { class: "form-control", rows: 5 } %>

            <div class="d-grid mt-3">
              <%= f.submit "Create Month",
                          class: "btn btn-success btn-lg" %>
            </div>

          <% end %>
        </div>
      </div>
    </div>

  </div>
</div>
